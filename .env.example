# ⚠️ Скопируйте в .env и заполните. Не коммитьте .env (см. .gitignore).

BOT_TOKEN=your_bot_token_from_botfather
ADMIN_IDS=123456789,987654321
ADMIN_CHAT_ID=

# Подписка: CHANNEL_ID — chat id канала (-100...); для кнопки «Подписаться» нужен CHANNEL_USERNAME или PUBLIC_CHANNEL
# Основной канал TopUp TJ (бот должен быть админом для постов турниров и т.п.)
CHANNEL_ID=-1003935737332
CHANNEL_CHAT_ID=-1003935737332
CHANNEL_USERNAME=TopUpTJ
REVIEWS_CHANNEL=@YourChannelUsername
PUBLIC_CHANNEL=@YourChannelUsername

# Поддержка: username (@name) или числовой Telegram user id
ADMIN_TG=@support_username

DC_CITY_NUMBER=+992000000000
ALIF_NUMBER=+992000000000
MASTERCARD_NUMBER=0000000000000000
MILLI_NUMBER=

# Опционально: пути к картинкам от корня проекта (иначе assets/welcome.jpg, assets/store.jpg)
START_PHOTO_PATH=
GAME_COVER_FF=
GAME_COVER_PUBG=
STORE_PHOTO_PATH=

# Все заказы, товары и статистика хранятся в этом файле — не удаляйте при обновлении кода.
# При старте бота создаётся копия в database/backups/ (последние 10).
DATABASE_PATH=./database/bot.db

# Web App «Подарки (NFT)» (React на Vercel): полный https://... после деплоя
# В BotFather добавьте домен Vercel для Mini App. ADMIN_TG как @username подмешивается в URL как ?seller=
GIFTS_WEBAPP_URL=https://top-up-seven.vercel.app/
