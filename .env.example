# ⚠️ Скопируйте в .env и заполните. Не коммитьте .env (см. .gitignore).
# Обязательны только BOT_TOKEN и ADMIN_IDS. Остальное — опционально.

BOT_TOKEN=your_bot_token_from_botfather
# Админы (владельцы): получают заказы и доступ к /admin. Через запятую.
ADMIN_IDS=123456789,987654321
ADMIN_CHAT_ID=

# Канал обязательной подписки (необязательно).
# CHANNEL_ID — chat id (-100...); для кнопки «Подписаться» нужен CHANNEL_USERNAME.
CHANNEL_ID=
CHANNEL_CHAT_ID=
CHANNEL_USERNAME=

# Кошельки (только Alif Mobi и DC City). Можно также менять в админ-панели «Кошельки».
DC_CITY_NUMBER=
ALIF_NUMBER=

# Опционально: пути к картинкам от корня проекта (иначе assets/welcome.jpg, assets/store.jpg)
START_PHOTO_PATH=
GAME_COVER_FF=
GAME_COVER_PUBG=
STORE_PHOTO_PATH=

# Все заказы, товары и статистика хранятся в этом файле — не удаляйте при обновлении кода.
# При старте бота создаётся копия в database/backups/ (последние 10).
DATABASE_PATH=./database/bot.db

# Опционально: контакт поддержки (@username) и Mini App «Подарки»
ADMIN_TG=
GIFTS_WEBAPP_URL=
